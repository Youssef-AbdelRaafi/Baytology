{
  "AppSettings": {
    "CorsPolicyName": "Baytology",
    "AllowedOrigins": [ "https://localhost:5001", "http://localhost:3000", "http://localhost:4200" ]
  },
  "StartupInitialization": {
    "SeedPropertyCsvOnStartup": false
  },
  "Email": {
    "DeliveryMode": "FilePickup",
    "PickupDirectory": "runtime-logs/emails"
  },
  "JwtSettings": {
    "Issuer": "Baytology.Api",
    "Audience": "Baytology.Clients"
  },
  "GoogleAuthSettings": {
    "ClientId": "[Enter your Google ClientId in secrets.json]",
    "ClientSecret": "[Enter your Google ClientSecret in secrets.json]"
  },
  "FacebookAuthSettings": {
    "AppId": "[Enter your Facebook AppId in secrets.json]",
    "AppSecret": "[Enter your Facebook AppSecret in secrets.json]"
  },
  "RabbitMq": {
    "Enabled": true
  },
  "Paymob": {
    "EnableLocalSimulation": true
  },
  "AiProcessing": {
    "EnableInProcessFallback": true,
    "EnableDelayedFallbackRecovery": true,
    "ExternalWorkerGracePeriodSeconds": 30,
    "DefaultSearchResultLimit": 10,
    "DefaultRecommendationResultLimit": 10
  },
  "ExternalAiServices": {
    "ChatbotEnabled": true,
    "ChatbotBaseUrl": "http://127.0.0.1:8001",
    "RecommendationEnabled": true,
    "RecommendationBaseUrl": "http://127.0.0.1:8002",
    "TimeoutSeconds": 120
  },
  "AiWorker": {
    "ServiceTokenHeaderName": "X-AI-Service-Token"
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  }
}
